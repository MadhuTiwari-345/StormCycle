rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Connection test rule
    match /_connection_test_/{testId} {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User document
    match /users/{userId} {
      function isValidUser(data, isCreate) {
        let isNameValid = (!('name' in data) || data.name == null || (data.name is string && data.name.size() > 0 && data.name.size() <= 100));
        let isEmailValid = (!('email' in data) || data.email == null || (data.email is string && data.email.size() > 0 && data.email.size() <= 200));
        let isLangValid = (!('preferredLanguage' in data) || data.preferredLanguage == null || (data.preferredLanguage in ['en', 'hi', 'ta', 'bn']));
        let isDobValid = (!('dateOfBirth' in data) || data.dateOfBirth == null || data.dateOfBirth is string);
        let isOnboardingValid = (!('onboardingCompleted' in data) || data.onboardingCompleted == null || data.onboardingCompleted is bool);

        return isCreate 
          ? (('name' in data) && isNameValid && ('email' in data) && isEmailValid && ('preferredLanguage' in data) && isLangValid)
          : (isNameValid && isEmailValid && isLangValid && isDobValid && isOnboardingValid);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming(), true) && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && isValidUser(incoming(), false);

      // User settings
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      // Private profile
      match /private/profile {
        function isValidProfile(data) {
          return (!('height' in data) || data.height == null || data.height is number) &&
                 (!('weight' in data) || data.weight == null || data.weight is number) &&
                 (!('avgCycleLength' in data) || data.avgCycleLength == null || data.avgCycleLength is int || data.avgCycleLength is number) &&
                 (!('avgPeriodLength' in data) || data.avgPeriodLength == null || data.avgPeriodLength is int || data.avgPeriodLength is number) &&
                 (!('cycleReminders' in data) || data.cycleReminders == null || data.cycleReminders is bool) &&
                 (!('pcodRiskAlerts' in data) || data.pcodRiskAlerts == null || data.pcodRiskAlerts is bool) &&
                 (!('lastPeriodDate' in data) || data.lastPeriodDate == null || data.lastPeriodDate is timestamp);
        }
        allow create, update: if isOwner(userId) && isValidProfile(incoming());
        allow delete: if isOwner(userId);
        allow get: if isOwner(userId);
      }

      // Cycle logs
      match /cycleLogs/{logId} {
        function isValidLog(data) {
          return data.date is timestamp &&
                 (!('flowIntensity' in data) || data.flowIntensity in ['none', 'light', 'medium', 'heavy']) &&
                 (!('isFirstDay' in data) || data.isFirstDay is bool) &&
                 (!('symptoms' in data) || data.symptoms is list) &&
                 (!('notes' in data) || data.notes is string);
        }
        allow list, delete: if isOwner(userId);
        allow get, create, update: if isOwner(userId) && isValidId(logId) && isValidLog(incoming());
      }

      // PCOD Screenings
      match /pcodScreenings/{screeningId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(screeningId);
      }

      // Chat Messages
      match /chatMessages/{messageId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(messageId);
      }
    }
  }
}
