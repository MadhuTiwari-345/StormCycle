rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User document
    match /users/{userId} {
      function isValidUser(data, isCreate) {
        let isNameValid = (data.name is string && data.name.size() > 0 && data.name.size() <= 100);
        let isEmailValid = (data.email is string && data.email.size() > 0 && data.email.size() <= 200);
        let isLangValid = (data.preferredLanguage in ['en', 'hi', 'ta', 'bn']);

        return isCreate 
          ? (isNameValid && isEmailValid && isLangValid)
          : (data.name == null || isNameValid) &&
            (data.email == null || isEmailValid) &&
            (data.preferredLanguage == null || isLangValid);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming(), true) && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && isValidUser(incoming(), false) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'preferredLanguage', 'dateOfBirth', 'onboardingCompleted']);

      // Private profile
      match /private/profile {
        function isValidProfile(data) {
          return (data.height == null || data.height is number) &&
                 (data.weight == null || data.weight is number) &&
                 (data.avgCycleLength == null || data.avgCycleLength is int) &&
                 (data.avgPeriodLength == null || data.avgPeriodLength is int);
        }
        allow write: if isOwner(userId) && isValidProfile(incoming());
        allow get: if isOwner(userId);
      }

      // Cycle logs
      match /cycleLogs/{logId} {
        function isValidLog(data) {
          return data.date is timestamp &&
                 (data.flowIntensity == null || data.flowIntensity in ['none', 'light', 'medium', 'heavy']) &&
                 (data.symptoms == null || data.symptoms is list);
        }
        allow list, delete: if isOwner(userId);
        allow get, create, update: if isOwner(userId) && isValidId(logId) && isValidLog(incoming());
      }

      // PCOD Screenings
      match /pcodScreenings/{screeningId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(screeningId);
      }

      // Chat Messages
      match /chatMessages/{messageId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(messageId);
      }
    }
  }
}
